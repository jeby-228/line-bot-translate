# Logging (optional, default: info)
RUST_LOG=info

# Groq API (共用)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Dev/test only: skip LINE webhook signature verification
# SKIP_LINE_SIGNATURE_VERIFY=true

# 泰文 LINE Messaging API Channel
TH_LINE_ACCESS_TOKEN=your_th_line_channel_access_token
TH_LINE_CHANNEL_SECRET=your_th_line_channel_secret

# 印尼文 LINE Messaging API Channel
ID_LINE_ACCESS_TOKEN=your_id_line_channel_access_token
ID_LINE_CHANNEL_SECRET=your_id_line_channel_secret